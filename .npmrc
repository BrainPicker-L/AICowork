# pnpm 使用扁平 node_modules，避免 asar 打包后 ESM 解析不到依赖（如 form-data）
node-linker=hoisted

# Electron 二进制下载镜像（国内可显著加速，首次打包约 113MB）
# 若不在国内或镜像异常，可注释掉以下两行改用 GitHub 官方
electron_mirror=https://npmmirror.com/mirrors/electron/
electron_builder_binaries_mirror=https://npmmirror.com/mirrors/electron-builder-binaries/
